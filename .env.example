# ─── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# ─── NVIDIA NIM (Primary AI Provider) ─────────────────────
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
# Optional: separate models for each agent
NVIDIA_PLANNER_MODEL=
NVIDIA_REVIEWER_MODEL=
NVIDIA_OPTIMIZER_MODEL=
# Fallback models (comma-separated, tried in order)
NVIDIA_FALLBACK_MODELS=meta/llama-3.1-70b-instruct,meta/llama-3.1-8b-instruct

# ─── Future Providers (uncomment to switch) ────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=

# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Active Provider ──────────────────────────────────────
AI_PROVIDER=nvidia

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=file:./data/bot.db

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── Bot Settings ─────────────────────────────────────────
CONFIRMATION_TIMEOUT=60
MAX_ACTIONS_PER_REQUEST=50

# ─── Deployment ───────────────────────────────────────────
PORT=3000
NODE_ENV=production
