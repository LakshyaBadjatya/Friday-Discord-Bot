{
  "name": "discord-server-architect",
  "version": "1.0.0",
  "description": "AI-powered Discord Server Architect Bot — build, manage, and organize servers with natural language.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker build -t discord-server-architect .",
    "docker:run": "docker run --env-file .env discord-server-architect"
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "server-architect",
    "management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "openai": "^4.103.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
